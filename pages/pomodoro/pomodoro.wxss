/* 还原原型整体色彩与布局 */
:root { --primary:#3366ff; --bg:#f5f7fb; --card:#ffffff; --border:#e2e8f0; --radius:28rpx; --text:#1f2933; --sub:#5f6b7a; }
.page{background:var(--bg);color:var(--text);line-height:1.5;padding-bottom:200rpx;}
.app-header{padding:32rpx 32rpx 16rpx;}
.app-title{font-size:40rpx;font-weight:600;}
.content{padding:32rpx;display:flex;flex-direction:column;gap:32rpx;}
.card{background:var(--card);border-radius:28rpx;padding:32rpx;box-shadow:0 32rpx 96rpx -32rpx rgba(0,0,0,.08);border:2rpx solid var(--border);}
.card-title{font-size:32rpx;font-weight:600;margin-bottom:24rpx;}

/* 圆环计时器 (使用 canvas 绘制进度) */
.circle-timer{width:440rpx;height:440rpx;border-radius:50%;margin:0 auto 32rpx;position:relative;background:#e5e7eb;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:16rpx;}
.ring-canvas{position:absolute;inset:0;width:100%;height:100%;}
.time-display{font-size:84rpx;font-weight:600;z-index:1;}
.picker{background:#ffffff;border:2rpx solid var(--border);padding:12rpx 20rpx;border-radius:20rpx;font-size:24rpx;min-width:200rpx;text-align:center;}
.picker.bind-skill{min-width:260rpx;}

/* 按钮组 */
.timer-actions{display:flex;justify-content:center;gap:24rpx;margin-top:8rpx;}
.btn{border:none;border-radius:20rpx;padding:16rpx 40rpx;font-size:28rpx;background:#e2e8f0;color:#1f2933;font-weight:500;}
.btn.primary{background:var(--primary);color:#fff;}
.btn.outline{background:transparent;border:2rpx solid var(--primary);color:var(--primary);}
.btn:disabled{opacity:.5;}

.reward-message{margin-top:24rpx;text-align:center;color:#16a34a;font-size:28rpx;font-weight:600;}

/* 历史 */
.pomodoro-history{display:flex;flex-direction:column;gap:16rpx;font-size:26rpx;}
.history-item{background:#f8fafc;padding:16rpx 20rpx;border-radius:20rpx;}

/* 底部导航 tabbar */
.tabbar{position:fixed;left:0;right:0;bottom:0;height:128rpx;background:#fff;border-top:2rpx solid var(--border);display:flex;align-items:center;justify-content:space-around;font-size:24rpx;z-index:50;box-shadow:0 -16rpx 48rpx -16rpx rgba(0,0,0,.06);}
.tab-item{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8rpx;color:#5f6b7a;}
.tab-item.active{color:var(--primary);}
.icon{font-size:44rpx;line-height:1;}

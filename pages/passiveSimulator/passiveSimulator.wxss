.sim-page{padding:16px;display:flex;flex-direction:column;gap:18px;background:#f5f7fb;min-height:100vh;}
.section{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:16px;box-shadow:0 4px 12px -4px rgba(0,0,0,.06);}
.form-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;}
.lab{font-size:14px;color:#374151;font-weight:500;}
.val-display{font-size:12px;color:#64748b;margin-top:-6px;margin-bottom:6px;}
.result .res-row{display:flex;align-items:center;justify-content:space-between;font-size:14px;margin:6px 0;}
.result .v{font-weight:600;color:#111827;}
.tip{font-size:12px;color:#6b7280;line-height:1.5;display:block;}

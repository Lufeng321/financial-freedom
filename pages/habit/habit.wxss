page, .habit-page{background:#f5f7fb;min-height:100vh;padding-bottom:70px;}
.app-header{padding:16px 16px 8px;}
.h1{font-size:20px;font-weight:600;}
.content{padding:16px;display:flex;flex-direction:column;gap:16px;}
.card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:16px;box-shadow:0 4px 12px -4px rgba(0,0,0,.08);} 
.card-title{font-size:16px;font-weight:600;margin-bottom:12px;display:flex;align-items:center;gap:8px;}
form{display:flex;flex-direction:column;gap:12px;}
.ipt, input{padding:10px 12px;border:1px solid #e2e8f0;border-radius:10px;background:#fff;font-size:14px;}
.picker-display{padding:10px 12px;border:1px solid #e2e8f0;border-radius:10px;background:#fff;}
.inline{display:flex;align-items:center;}
.btn{border:none;cursor:pointer;border-radius:10px;padding:8px 14px;font-size:14px;background:#e2e8f0;color:#1f2933;transition:.2s;font-weight:500;}
.btn.primary{background:#3366ff;color:#fff;}
.btn.small{font-size:12px;padding:4px 8px;}
.btn.full{width:100%;}
.btn.danger{color:#d92c2c;}
.habit-list{list-style:none;display:flex;flex-direction:column;gap:10px;}
.habit-row{display:flex;align-items:center;justify-content:space-between;padding:10px 12px;background:#f8fafc;border-radius:10px;}
.habit-row .info{display:flex;flex-direction:column;gap:2px;}
.streak{font-size:12px;color:#5f6b7a;}
.habit-calendar{margin-top:10px;padding-top:10px;border-top:1px dashed #e2e8f0;}
.calendar-head{font-size:12px;color:#5f6b7a;margin-bottom:6px;display:flex;align-items:center;gap:6px;}
.calendar-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;font-size:12px;}
.calendar-grid.mini .day{padding:4px;font-size:11px;border-radius:4px;}
.day{background:#f1f5f9;padding:6px 0;border-radius:6px;text-align:center;}
.day.done{background:#3366ff;color:#fff;}
.sub-note{font-size:12px;color:#5f6b7a;font-weight:400;}
.habit-heatmap{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;font-size:10px;}
.habit-heatmap .cell{position:relative;width:100%;padding-top:100%;border-radius:4px;background:#e5e7eb;overflow:hidden;}
.habit-heatmap .cell[data-c="0"]{background:#f1f5f9;}
.habit-heatmap .cell[data-c="1"]{background:#cfe8ff;}
.habit-heatmap .cell[data-c="2"]{background:#99caff;}
.habit-heatmap .cell[data-c="3"]{background:#5aa6ff;}
.habit-heatmap .cell[data-c="4"],.habit-heatmap .cell[data-c="5"]{background:#1d6fe6;}
.tip-text{font-size:13px;color:#5f6b7a;line-height:1.5;display:block;}
/* 模板 Chips */
.habit-templates{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:12px;}
.tpl-chip{background:#e0f2fe;color:#0369a1;padding:6px 10px;border-radius:20px;font-size:12px;}
.tpl-chip:active{background:#bae6fd;}

page{background:#f5f6fa;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,'Noto Sans SC','Microsoft YaHei',sans-serif;color:#222;font-size:14px;}
.page{padding:12px 12px 40px;}
.app-header{padding:4px 4px 12px;}
.h1{font-size:20px;font-weight:600;}
.content{display:flex;flex-direction:column;gap:16px;}

.card{background:#fff;border-radius:12px;padding:14px 14px 18px;box-shadow:0 2px 6px -2px rgba(0,0,0,.08),0 4px 12px -4px rgba(0,0,0,.06);position:relative;}
.card-title{display:block;font-size:16px;font-weight:600;margin-bottom:10px;}
.sub-note{color:#888;font-size:12px;}

.form-item{margin-bottom:14px;display:flex;flex-direction:column;gap:6px;}
.form-item label{font-size:13px;font-weight:500;color:#444;}
.picker-display{background:#f1f3f6;padding:8px 10px;border-radius:8px;min-height:36px;display:flex;align-items:center;}

.rate{display:flex;gap:8px;}
.mood-icon{font-size:26px;opacity:.45;transition:.2s;}
.mood-icon.active{opacity:1;transform:scale(1.12);} 
.mood-icon:active{transform:scale(.92);}

.diary-text{width:100%;min-height:140px;background:#f8f9fb;border-radius:10px;padding:10px 12px;box-sizing:border-box;line-height:1.5;border:none;}
.diary-text:focus{outline:2px solid #4a8dff;background:#fff;}

.image-preview-grid{display:flex;flex-wrap:wrap;gap:10px;}
.img-box{width:76px;height:76px;border-radius:10px;overflow:hidden;position:relative;background:#f0f2f5;}
.img-box image{width:100%;height:100%;}
.remove-btn{position:absolute;top:0;right:0;background:rgba(0,0,0,.55);color:#fff;border:none;border-radius:0 0 0 6px;width:24px;height:24px;line-height:24px;font-size:16px;padding:0;}

.btn{background:#2563eb;color:#fff;border:none;border-radius:8px;padding:8px 14px;font-size:14px;line-height:1.1;}
.btn.small{background:#efefef;color:#333;padding:8px 10px;font-size:12px;}
.btn.small:active{background:#e2e2e2;}

.save-status{font-size:12px;color:#666;position:absolute;bottom:6px;right:12px;}

/* History */
.toolbar{display:flex;gap:8px;margin-bottom:10px;}
.search{flex:1;background:#f1f3f6;border:none;border-radius:20px;padding:8px 14px;font-size:14px;}
.search:focus{outline:2px solid #4a8dff;background:#fff;}
.timeline{display:flex;flex-direction:column;gap:10px;}
.entry{background:#f7f9fb;padding:10px 12px;border-radius:10px;line-height:1.45;position:relative;font-size:13px;}
.entry .time{font-weight:600;margin-right:6px;}

/* Mood color accents */
.mood-1{border-left:4px solid #94a3b8;}
.mood-2{border-left:4px solid #60a5fa;}
.mood-3{border-left:4px solid #34d399;}
.mood-4{border-left:4px solid #fbbf24;}
.mood-5{border-left:4px solid #f87171;}

@media (prefers-color-scheme:dark){
	page{background:#111;color:#ddd;}
	.card{background:#1e1f24;box-shadow:0 2px 8px -3px rgba(0,0,0,.8);} 
	.picker-display,.diary-text,.search{background:#2a2c32;color:#ddd;}
	.entry{background:#22252b;}
	.btn.small{background:#2d3138;color:#ddd;}
}

/* 总结展示 */
.summary-box{background:#f4f6f9;border:1px solid #e3e8ef;border-radius:10px;padding:10px 12px;margin-top:8px;}
.sum-title{display:block;font-weight:600;color:#333;margin-bottom:6px;font-size:13px;}
.sum-json{font-family:Menlo,Consolas,monospace;font-size:11px;white-space:pre-wrap;word-break:break-all;color:#444;}

@media (prefers-color-scheme:dark){
	.kw-chip{background:#2d3138;color:#ddd;border-color:#3a4048;}
	.kw-chip.on,.kw-chip.sel{background:#1d4ed8;border-color:#1d4ed8;}
	.summary-box{background:#1f242a;border-color:#333;}
	.sum-title{color:#ccc;}
	.sum-json{color:#bbb;}
	.empty{color:#666;}
}

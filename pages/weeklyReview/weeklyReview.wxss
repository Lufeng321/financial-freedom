.review-page{padding:16px;display:flex;flex-direction:column;gap:16px;background:#f5f7fb;min-height:100vh;}
.tabs{display:flex;gap:12px;}
.tab{padding:6px 14px;border-radius:20px;background:#e2e8f0;font-size:14px;}
.tab.active{background:#3366ff;color:#fff;font-weight:600;}
.range-picker{display:flex;align-items:center;justify-content:center;gap:12px;font-size:14px;}
.cards{display:flex;flex-direction:column;gap:14px;}
.card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:14px;box-shadow:0 4px 10px -4px rgba(0,0,0,.06);}
.card.kpi .row{display:flex;align-items:center;justify-content:space-between;font-size:14px;margin-bottom:4px;}
.card .title{font-size:15px;font-weight:600;margin-bottom:8px;display:block;}
.card.list .row{display:flex;align-items:center;justify-content:space-between;font-size:14px;padding:2px 0;}
.val{font-weight:600;}
.empty{font-size:12px;color:#6b7280;margin-top:4px;}
.share-btn{margin-top:30px;}
.summary .summary-text{font-size:12px;line-height:1.6;color:#475569;}
.summary .chip{background:#e0f2fe;color:#0369a1;padding:2px 6px;border-radius:10px;margin-right:6px;font-size:11px;}
